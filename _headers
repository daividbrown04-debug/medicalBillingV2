# Security & caching headers for Netlify / Cloudflare Pages
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; img-src 'self' data:; media-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'sha256-ewOEiEV44tauQ/jGDcLUxdb6cTDAiJbLVi0ptahAFOM=' https://cdnjs.cloudflare.com; connect-src 'self'; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests

# Long-cache fingerprintable static assets
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# HTML should always revalidate
/*.html
  Cache-Control: public, max-age=0, must-revalidate
